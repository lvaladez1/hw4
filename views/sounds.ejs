<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>

<body>
    <%- include('partials/nav')%>

    <div class="container py-4">
        <div class="card shadow-sm mx-auto" style="max-width: 800px;">
            <img src="<%= soundImg %>"
                 class="card-img-top"
                 alt="sound artwork"
                 onerror="this.onerror=null; this.src='/img/no_image.png';">

            <div class="card-body text-center">
                <h3 class="card-title">
                    <%= soundTitle %>
                </h3>

                <p class="text-muted">
                    <strong>Artist:</strong>
                    <%= soundArtist %>
                </p>

                <p>
                    <strong>Date:</strong>
                    <%= soundDate %>
                </p>

                <p>
                    <strong>Multimedia available:</strong>
                    <span class="<%= hasSoundMedia === 'Yes' ? 'text-success' : 'text-danger' %>">
                        <%= hasSoundMedia %>
                    </span>
                </p>

                <p class="card-text">
                    <%- soundDescription %>
                </p>

                <% if (soundId) { %>
                    <a href="https://www.artic.edu/artworks/<%= soundId %>"
                       class="btn btn-outline-primary"
                       target="_blank">
                        View museum page
                    </a>
                <% } %>
            </div>
        </div>
    </div>

    <%- include('partials/paginationNav', { currentPage, baseRoute }) %>
    <%- include('partials/footer')%>
</body>
</html>