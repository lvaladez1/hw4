<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>

<body>
    <%- include('partials/nav')%>

    <div class="container py-4">
        <div class="card shadow-sm mx-auto" style="max-width: 800px;">
            <img src="<%= videoImg %>" class="card-img-top" alt="video artwork">

            <div class="card-body text-center">
                <h3 class="card-title">
                    <%= videoTitle %>
                </h3>

                <p class="text-muted">
                    <strong>Artist:</strong>
                    <%= videoArtist %>
                </p>

                <p>
                    <strong>Medium:</strong>
                    <%= videoMedium %>
                </p>

                <p>
                    <strong>Date:</strong>
                    <%= videoDate %>
                </p>

                <p class="card-text">
                    <%- videoDescription %>
                </p>

                <% if (videoId) { %>
                    <a href="https://www.artic.edu/artworks/<%= videoId %>"
                       class="btn btn-outline-primary"
                       target="_blank">
                        View museum page
                    </a>
                <% } %>
            </div>
        </div>
    </div>

    <%- include('partials/paginationNav', { currentPage, baseRoute }) %>
    <%- include('partials/footer')%>
</body>
</html>